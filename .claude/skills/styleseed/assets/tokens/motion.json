{
  "$description": "StyleSeed - Motion / Animation Tokens",
  "duration": {
    "fast": "100ms",
    "normal": "200ms",
    "slow": "350ms"
  },
  "easing": {
    "default": "cubic-bezier(0.4, 0, 0.2, 1)",
    "in": "cubic-bezier(0.4, 0, 1, 1)",
    "out": "cubic-bezier(0, 0, 0.2, 1)",
    "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
  },
  "usage": {
    "hover": "duration-fast + ease-default",
    "enter": "duration-normal + ease-out",
    "exit": "duration-fast + ease-in",
    "spring": "duration-slow + ease-spring (for playful micro-interactions)"
  },
  "a11y": "All animations are disabled when prefers-reduced-motion: reduce is set. See base.css."
}
