# SQL Agent v2 — 環境變數範例
# 複製為 .env 後填入實際值；.env 已在 .gitignore 中，不會被提交。
# 每個變數的權威定義見 app/config.py（pydantic-settings，啟動即驗證）。
# 本機開發不設定任何變數也可直接跑（SQLite + dev-only 預設值）。

# ---- LLM gateway（OpenAI 相容 Chat Completions）----
# gateway 的 base URL，例如 https://llm-gateway.internal/v1
LLM_BASE_URL=
# gateway 的 API key
LLM_API_KEY=
# 使用的模型名稱，例如 gpt-4o-mini 或內網 gateway 的自訂模型代號
LLM_MODEL=
# 是否驗證 gateway 的 TLS 憑證；內網多為自簽憑證，預設 false
LLM_VERIFY=false
# LLM 呼叫的 read timeout（秒）
LLM_TIMEOUT=120.0
# 覆蓋自動偵測的 CapabilityProfile（JSON 字串，除錯用；一般留空）
LLM_FORCE_PROFILE=

# ---- 平台自身資料庫 ----
# 未設定時預設本機 SQLite（零設定可跑）；正式環境改為 PostgreSQL，
# driver 需用 asyncpg（SQLAlchemy async），例如：
# postgresql+asyncpg://sql_agent:sql_agent@localhost:5432/sql_agent
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ---- 安全 ----
# 一般用途的密鑰（session/token 簽章等）；正式環境務必更換，不可用預設值
SECRET_KEY=dev-only-secret
# 32-byte hex，用於 AES-256-GCM 加密使用者資料庫連線字串；產生方式：
#   python -c "import os; print(os.urandom(32).hex())"
DB_ENCRYPTION_KEY=
# change request 審批的過渡機制 token（Phase 7 正式 JWT/角色上線前使用）；
# 未設定時審批端點回 403（功能停用）
ADMIN_TOKEN=

# ---- 認證（Phase 7 JWT）----
# false（預設）：所有端點維持匿名行為（v0.5 相容）；true：強制 JWT 認證、
# session 所有權過濾、change request 審批改看 JWT role=admin
AUTH_ENABLED=false
# access token 存活分鐘數 / refresh token 存活天數
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
# /auth/login 的 per-IP 滑動視窗限流（次數 / 視窗秒數）
AUTH_RATE_LIMIT_LOGIN_MAX=5
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60.0
# 一般端點限流參數（保留給後續擴充，目前僅 /auth/login 實際套用）
AUTH_RATE_LIMIT_GENERAL_MAX=60
AUTH_RATE_LIMIT_GENERAL_WINDOW_SECONDS=60.0

# ---- AD（Active Directory）登入 ----
# 部署於 Windows Server IIS（HttpPlatformHandler）時可啟用：IIS Windows SSO
# 自動登入 + ldap3 SIMPLE bind 手動登入後備 + AD 群組授權；本地 email+密碼
# 帳號保留作後備。false（預設）時本區塊完全不生效，行為與現在完全相同。
# 設定慣例對齊公司實戰驗證的 python-iis-ad-deploy skill（references/ad-auth.md）。
AD_ENABLED=false
# 【僅供開發】true 時不連真實 AD：任何非空密碼皆放行、發固定測試身分；
# 正式環境務必為 false
AD_MOCK=false
# AD/LDAP 伺服器：ldap:// + NetBIOS 短名，例如 ldap://KH
# （登入 bind 用 NETBIOS\samaccount 格式，NetBIOS 即從此短名導出：KH\K11879）
AD_SERVER=
# 完整網域名，例如 kh.asegroup.com（AD 條目沒有 mail 屬性時組使用者 email 用）
AD_DOMAIN=
# LDAP 搜尋根目錄，例如 DC=kh,DC=asegroup,DC=com
AD_BASE_DN=
# 服務帳號（選填）：SSO 自動登入路徑（無使用者密碼）查群組/顯示名用；
# 未設定時 SSO 使用者只發基本 user 角色（不做匿名查詢）。
# 可填裸帳號（自動補 NETBIOS\ 前綴）、DOMAIN\user、UPN 或完整 DN
AD_BIND_DN=
AD_BIND_PW=
# AD 管理員群組（CN 名或完整 DN 皆可，大小寫不敏感）；使用者 memberOf 含此
# 群組時，平台角色為 admin，否則為一般 user；每次登入依當下群組成員資格刷新
AD_ADMIN_GROUP=
# 是否啟用 GET /auth/sso（IIS Windows SSO 自動登入端點）；false 時該端點回 404
AD_SSO_ENABLED=false
# Windows token handle 模式使用的 header 名稱（IIS HttpPlatformHandler
# forwardWindowsAuthToken 對應）；token 以 ctypes 解碼，僅 Windows 環境支援，
# 非 Windows 一律回 501
AD_SSO_HEADER=X-IIS-WindowsAuthToken
# 【安全警告】設定此變數即啟用 REMOTE_USER 式 header 信任模式：平台會無條件
# 信任該 header 宣稱的使用者身分（等同免密碼登入）。此 header 只能由 IIS
# （IIS Windows Authentication，經 HttpPlatformHandler 反向代理時）注入，
# 平台必須只透過 IIS 對外服務，絕不能讓請求繞過 IIS 直接打到 uvicorn，否則
# 任何人都能偽造此 header 冒充他人登入。未設定（預設）時停用此模式。
AD_SSO_REMOTE_USER_HEADER=

# ---- 伺服器 ----
# uvicorn 綁定的 host；容器內一律用 0.0.0.0
HOST=127.0.0.1
# 是否開啟 debug 模式（FastAPI debug，正式環境務必為 false）
DEBUG=false
