# ── Pensieve AI API（必填）──────────────────────────────
PENSIEVE_TOKEN=your_token_here
PENSIEVE_EMPNO=your_empno_here
PENSIEVE_URL=https://pensieve.kh.asegroup.com/api/flow_chat/
PENSIEVE_BUILDING=question
PENSIEVE_VERIFY=false

# 現有 DB 結構作為 LLM 記憶參考（選填）。設定 vector_id 後，匯入的現有資料庫
# 結構會在對話動到現有表時上傳到該 vector（flow 已綁定此 vector store）。
# 未設定時自動退回 system-prompt 注入 fallback。
PENSIEVE_VECTOR_URL=https://pensieve.kh.asegroup.com/api/uploadVector/
PENSIEVE_VECTOR_ID=

# ── Flask ──────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-32-char-string

# ── 儲存後端（選填）────────────────────────────────────
# 設定後，Session 改存於 PostgreSQL；未設定則 fallback 至 data/*.json
# DATABASE_URL=postgresql://user:pass@host:5432/sql_agent
# DATA_DIR=data   # JSON 模式的資料目錄（預設 data/）
